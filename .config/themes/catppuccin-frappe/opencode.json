{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "primary": "#8caaee",
    "on_primary": "#303446",
    "secondary": "#99d1db",
    "on_secondary": "#303446",
    "surface": "#303446",
    "on_surface": "#c6d0f5",
    "surface_variant": "#51576d",
    "on_surface_variant": "#b5bfe2",
    "background": "#303446",
    "on_background": "#c6d0f5",
    "error": "#e78284",
    "on_error": "#303446",
    "outline": "#a5adce",
    "outline_variant": "#51576d"
  },
  "theme": {
    "primary": {
      "dark": "primary",
      "light": "primary"
    },
    "secondary": {
      "dark": "secondary",
      "light": "secondary"
    },
    "accent": {
      "dark": "primary",
      "light": "primary"
    },
    "error": {
      "dark": "error",
      "light": "error"
    },
    "warning": {
      "dark": "secondary",
      "light": "secondary"
    },
    "success": {
      "dark": "secondary",
      "light": "secondary"
    }
  }
}
