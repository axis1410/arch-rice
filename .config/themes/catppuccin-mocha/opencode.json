{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "primary": "#b4befe",
    "on_primary": "#1e1e2e",
    "secondary": "#89b4fa",
    "on_secondary": "#1e1e2e",
    "surface": "#1e1e2e",
    "on_surface": "#cdd6f4",
    "surface_variant": "#45475a",
    "on_surface_variant": "#bac2de",
    "background": "#1e1e2e",
    "on_background": "#cdd6f4",
    "error": "#f38ba8",
    "on_error": "#1e1e2e",
    "outline": "#a6adc8",
    "outline_variant": "#45475a"
  },
  "theme": {
    "primary": {
      "dark": "primary",
      "light": "primary"
    },
    "secondary": {
      "dark": "secondary",
      "light": "secondary"
    },
    "accent": {
      "dark": "primary",
      "light": "primary"
    },
    "error": {
      "dark": "error",
      "light": "error"
    },
    "warning": {
      "dark": "secondary",
      "light": "secondary"
    },
    "success": {
      "dark": "secondary",
      "light": "secondary"
    }
  }
}
