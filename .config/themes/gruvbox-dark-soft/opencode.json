{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "primary": "#d79921",
    "on_primary": "#32302f",
    "secondary": "#98971a",
    "on_secondary": "#32302f",
    "surface": "#32302f",
    "on_surface": "#ebdbb2",
    "surface_variant": "#504945",
    "on_surface_variant": "#d5c4a1",
    "background": "#32302f",
    "on_background": "#ebdbb2",
    "error": "#cc241d",
    "on_error": "#32302f",
    "outline": "#bdae93",
    "outline_variant": "#504945"
  },
  "theme": {
    "primary": {
      "dark": "primary",
      "light": "primary"
    },
    "secondary": {
      "dark": "secondary",
      "light": "secondary"
    },
    "accent": {
      "dark": "primary",
      "light": "primary"
    },
    "error": {
      "dark": "error",
      "light": "error"
    },
    "warning": {
      "dark": "secondary",
      "light": "secondary"
    },
    "success": {
      "dark": "secondary",
      "light": "secondary"
    }
  }
}
