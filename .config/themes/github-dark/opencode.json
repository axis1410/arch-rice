{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "primary": "#58a6ff",
    "on_primary": "#0d1117",
    "secondary": "#79c0ff",
    "on_secondary": "#0d1117",
    "surface": "#0d1117",
    "on_surface": "#c9d1d9",
    "surface_variant": "#21262d",
    "on_surface_variant": "#8b949e",
    "background": "#0d1117",
    "on_background": "#c9d1d9",
    "error": "#f85149",
    "on_error": "#0d1117",
    "outline": "#6e7681",
    "outline_variant": "#21262d"
  },
  "theme": {
    "primary": {
      "dark": "primary",
