{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "primary": "#a98a78",
    "on_primary": "#292522",
    "secondary": "#78997a",
    "on_secondary": "#292522",
    "surface": "#292522",
    "on_surface": "#ece1d7",
    "surface_variant": "#4a443e",
    "on_surface_variant": "#c1a78e",
    "background": "#292522",
    "on_background": "#ece1d7",
    "error": "#d47766",
    "on_error": "#292522",
    "outline": "#867462",
    "outline_variant": "#4a443e"
  },
  "theme": {
    "primary": {
      "dark": "primary",
      "light": "primary"
    },
    "secondary": {
      "dark": "secondary",
      "light": "secondary"
    },
    "accent": {
      "dark": "primary",
      "light": "primary"
    },
    "error": {
      "dark": "error",
      "light": "error"
    },
    "warning": {
      "dark": "secondary",
      "light": "secondary"
