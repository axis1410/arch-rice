{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "primary": "#82aaff",
    "on_primary": "#0f111a",
    "secondary": "#89ddff",
    "on_secondary": "#0f111a",
    "surface": "#0f111a",
    "on_surface": "#a6accd",
    "surface_variant": "#2a2e42",
    "on_surface_variant": "#828bb8",
    "background": "#0f111a",
    "on_background": "#a6accd",
    "error": "#f07178",
    "on_error": "#0f111a",
    "outline": "#5c6783",
    "outline_variant": "#2a2e42"
  },
  "theme": {
    "primary": {
      "dark": "primary",
      "light": "primary"
    },
    "secondary": {
      "dark": "secondary",
      "light": "secondary"
    },
    "accent": {
      "dark": "primary",
      "light": "primary"
    },
    "error": {
      "dark": "error",
      "light": "error"
    },
    "warning": {
      "dark": "secondary",
      "light": "secondary"
    },
    "success": {
      "dark": "secondary",
      "light": "secondary"
    }
  }
}
