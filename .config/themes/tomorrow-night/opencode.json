{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "primary": "#81a2be",
    "on_primary": "#1d1f21",
    "secondary": "#8abeb7",
    "on_secondary": "#1d1f21",
    "surface": "#1d1f21",
    "on_surface": "#c5c8c6",
    "surface_variant": "#373b41",
    "on_surface_variant": "#b4b7b4",
    "background": "#1d1f21",
    "on_background": "#c5c8c6",
    "error": "#cc6666",
    "on_error": "#1d1f21",
    "outline": "#969896",
    "outline_variant": "#373b41"
  },
  "theme": {
    "primary": {
      "dark": "primary",
      "light": "primary"
    },
    "secondary": {
      "dark": "secondary",
      "light": "secondary"
    },
    "accent": {
      "dark": "primary",
      "light": "primary"
    },
    "error": {
      "dark": "error",
      "light": "error"
    },
    "warning": {
      "dark": "secondary",
      "light": "secondary"
    },
    "success": {
      "dark": "secondary",
      "light": "secondary"
    }
  }
}
