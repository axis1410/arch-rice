{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "primary": "#7aa2f7",
    "on_primary": "#1a1b26",
    "secondary": "#7dcfff",
    "on_secondary": "#1a1b26",
    "surface": "#1a1b26",
    "on_surface": "#c0caf5",
    "surface_variant": "#3b4261",
    "on_surface_variant": "#a9b1d6",
    "background": "#1a1b26",
    "on_background": "#c0caf5",
    "error": "#f7768e",
    "on_error": "#1a1b26",
    "outline": "#9aa5ce",
    "outline_variant": "#3b4261"
  },
  "theme": {
    "primary": {
      "dark": "primary",
      "light": "primary"
    },
    "secondary": {
      "dark": "secondary",
      "light": "secondary"
    },
    "accent": {
      "dark": "primary",
      "light": "primary"
    },
    "error": {
      "dark": "error",
      "light": "error"
    },
    "warning": {
      "dark": "secondary",
      "light": "secondary"
    },
    "success": {
      "dark": "secondary",
      "light": "secondary"
    }
  }
}
