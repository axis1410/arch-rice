{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "primary": "#39bae6",
    "on_primary": "#0f1419",
    "secondary": "#95e6cb",
    "on_secondary": "#0f1419",
    "surface": "#0f1419",
    "on_surface": "#bfbdb6",
    "surface_variant": "#253340",
    "on_surface_variant": "#98958e",
    "background": "#0f1419",
    "on_background": "#bfbdb6",
    "error": "#f07178",
    "on_error": "#0f1419",
    "outline": "#6c7380",
    "outline_variant": "#253340"
  },
  "theme": {
    "primary": {
      "dark": "primary",
      "light": "primary"
    },
    "secondary": {
      "dark": "secondary",
      "light": "secondary"
    },
    "accent": {
      "dark": "primary",
      "light": "primary"
    },
    "error": {
      "dark": "error",
      "light": "error"
    },
    "warning": {
