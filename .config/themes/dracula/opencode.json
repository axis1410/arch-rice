{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "primary": "#bd93f9",
    "on_primary": "#282a36",
    "secondary": "#ff79c6",
    "on_secondary": "#282a36",
    "surface": "#282a36",
    "on_surface": "#f8f8f2",
    "surface_variant": "#44475a",
    "on_surface_variant": "#bfbfbf",
    "background": "#282a36",
    "on_background": "#f8f8f2",
    "error": "#ff5555",
    "on_error": "#282a36",
    "outline": "#6272a4",
    "outline_variant": "#44475a"
  },
  "theme": {
    "primary": {
      "dark": "primary",
      "light": "primary"
    },
    "secondary": {
      "dark": "secondary",
      "light": "secondary"
    },
    "accent": {
      "dark": "primary",
      "light": "primary"
    },
    "error": {
      "dark": "error",
      "light": "error"
    },
    "warning": {
      "dark": "secondary",
      "light": "secondary"
    },
    "success": {
      "dark": "secondary",
      "light": "secondary"
    }
  }
}
