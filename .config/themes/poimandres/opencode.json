{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "primary": "#89ddff",
    "on_primary": "#1b1e28",
    "secondary": "#5de4c7",
    "on_secondary": "#1b1e28",
    "surface": "#1b1e28",
    "on_surface": "#e4f0fb",
    "surface_variant": "#4b5263",
    "on_surface_variant": "#a6accd",
    "background": "#1b1e28",
    "on_background": "#e4f0fb",
    "error": "#d0679d",
    "on_error": "#1b1e28",
    "outline": "#767c9d",
    "outline_variant": "#4b5263"
  },
  "theme": {
    "primary": {
      "dark": "primary",
      "light": "primary"
    },
    "secondary": {
      "dark": "secondary",
      "light": "secondary"
    },
    "accent": {
      "dark": "primary",
      "light": "primary"
    },
    "error": {
      "dark": "error",
      "light": "error"
    },
    "warning": {
      "dark": "secondary",
      "light": "secondary"
    },
    "success": {
      "dark": "secondary",
      "light": "secondary"
    }
  }
}
