{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "primary": "#fabd2f",
    "on_primary": "#1d2021",
    "secondary": "#b8bb26",
    "on_secondary": "#1d2021",
    "surface": "#1d2021",
    "on_surface": "#ebdbb2",
    "surface_variant": "#3c3836",
    "on_surface_variant": "#d5c4a1",
    "background": "#1d2021",
    "on_background": "#ebdbb2",
    "error": "#fb4934",
    "on_error": "#1d2021",
    "outline": "#a89984",
    "outline_variant": "#3c3836"
  },
  "theme": {
    "primary": {
      "dark": "primary",
      "light": "primary"
    },
    "secondary": {
      "dark": "secondary",
      "light": "secondary"
    },
    "accent": {
      "dark": "primary",
      "light": "primary"
    },
    "error": {
      "dark": "error",
      "light": "error"
    },
    "warning": {
      "dark": "secondary",
      "light": "secondary"
    },
    "success": {
      "dark": "secondary",
      "light": "secondary"
    }
  }
}
