{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "primary": "#d79921",
    "on_primary": "#1d2021",
    "secondary": "#98971a",
    "on_secondary": "#1d2021",
    "surface": "#1d2021",
    "on_surface": "#ebdbb2",
    "surface_variant": "#504945",
    "on_surface_variant": "#a89984",
    "background": "#1d2021",
    "on_background": "#ebdbb2",
    "error": "#cc241d",
    "on_error": "#1d2021",
    "outline": "#928374",
    "outline_variant": "#504945"
  },
  "theme": {
    "primary": {
      "dark": "primary",
      "light": "primary"
    },
    "secondary": {
      "dark": "secondary",
      "light": "secondary"
    },
    "accent": {
      "dark": "primary",
      "light": "primary"
    },
    "error": {
      "dark": "error",
      "light": "error"
    },
    "warning": {
      "dark": "secondary",
      "light": "secondary"
    },
    "success": {
      "dark": "secondary",
      "light": "secondary"
    }
  }
}
