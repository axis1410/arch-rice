{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "primary": "#8ab4f8",
    "on_primary": "#101010",
    "secondary": "#89dceb",
    "on_secondary": "#101010",
    "surface": "#101010",
    "on_surface": "#e6e6e6",
    "surface_variant": "#2a2a2a",
    "on_surface_variant": "#b5b5b5",
    "background": "#101010",
    "on_background": "#e6e6e6",
    "error": "#f38ba8",
    "on_error": "#101010",
    "outline": "#7a7a7a",
    "outline_variant": "#2a2a2a"
  },
  "theme": {
    "primary": {
      "dark": "primary",
      "light": "primary"
    },
    "secondary": {
      "dark": "secondary",
      "light": "secondary"
    },
    "accent": {
      "dark": "primary",
      "light": "primary"
    },
    "error": {
      "dark": "error",
      "light": "error"
    },
    "warning": {
      "dark": "secondary",
      "light": "secondary"
    },
    "success": {
      "dark": "secondary",
      "light": "secondary"
    }
  }
}
